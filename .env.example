# SpoqAssist — copy to .env (never commit secrets)

# Hub API
SPOQ_ENV=dev
SPOQ_LOG_LEVEL=INFO
# Never log mailbox subject/body/draft content or Bearer tokens

# Postgres (Compose service `db`)
POSTGRES_USER=spoq
POSTGRES_PASSWORD=spoq_dev_change_me
POSTGRES_DB=spoqassist
DATABASE_URL=postgresql+psycopg://spoq:spoq_dev_change_me@db:5432/spoqassist

# Inference — stub for CI/dev; ollama on Mac Studio; vllm on DGX Spark
INFERENCE_MODE=stub
# INFERENCE_MODE=ollama
# INFERENCE_MODE=vllm

# Ollama (Mac Studio legacy)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_RERANK_MODEL=qwen3-reranker:0.6b
OLLAMA_INSTRUCT_MODEL=qwen3:14b

# vLLM (DGX Spark) — separate services per model role
VLLM_CLASSIFY_URL=http://localhost:8001/v1
VLLM_DRAFT_URL=http://localhost:8002/v1
VLLM_EMBED_URL=http://localhost:8003/v1
VLLM_CLASSIFY_MODEL=Qwen/Qwen3.6-27B
VLLM_DRAFT_MODEL=Qwen/Qwen3-72B
VLLM_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
VLLM_DRAFT_TIMEOUT=30.0
VLLM_CLASSIFY_TIMEOUT=10.0
# Embeddings stored as 4096-d vectors on DGX Spark (1024-d on legacy Ollama)

# Entra ID — multi-entity JWT validation (Story 1.2)
ENTRA_TENANT_IDS=00000000-0000-0000-0000-000000000001
ENTRA_API_AUDIENCE=api://spoqassist
# ENTRA_ENTITIES=[{"tenant_id":"00000000-0000-0000-0000-000000000001","audience":"api://spoqassist"}]

# Graph connector (Story 1.4) — secrets stay on Mac Studio hub only
GRAPH_MODE=stub
# GRAPH_MODE=obo
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
GRAPH_SCOPES=https://graph.microsoft.com/Mail.Read,https://graph.microsoft.com/Mail.Read.Shared,https://graph.microsoft.com/Mail.Send
# Mail.Send required for confirm-outbound send/forward

# Ops principals for non-content connector config (FR36 / Story 1.6)
OPS_PRINCIPAL_OIDS=

# Add-in → hub (dev)
# Used by webpack DefinePlugin as process.env.HUB_BASE_URL
HUB_BASE_URL=http://localhost:8000
